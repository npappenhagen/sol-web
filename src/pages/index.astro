---
import Layout from '@/layouts/Layout.astro'
import Hero from '@/components/home/Hero.astro'
import IntroBlock from '@/components/home/IntroBlock.astro'
import ServicePreview from '@/components/home/ServicePreview.astro'
import { getEntry } from 'astro:content'
import { getAllPortraitImages } from '@/lib/carousel-images'

const [home, servicesPage] = await Promise.all([
  getEntry('pages', 'home'),
  getEntry('pages', 'services'),
])
const {
  hero_heading,
  hero_position,
  hero_focal_x,
  hero_focal_y,
  hero_carousel_speed,
  intro_label,
  intro_heading,
  intro_body,
  intro_headshot,
} = home.data

// Get FULL portrait image pool for client-side selection
// Pull from portraits category for best variety on home page
const allPortraitImages = await getAllPortraitImages(['portraits'])

const activeServices = servicesPage.data.services.filter((s: { portfolio_slug?: string }) => s.portfolio_slug);
---

<Layout title="Home">
  <Hero
    slides={allPortraitImages}
    heading={hero_heading}
    position={hero_position}
    focalX={hero_focal_x}
    focalY={hero_focal_y}
    carouselSpeed={hero_carousel_speed}
    usePreSelection={true}
    poolId="hero-home-pool"
    pageId="home"
    displayCount={4}
  />
  <div class="section-divider my-0" data-divider aria-hidden="true" />
  <IntroBlock label={intro_label} heading={intro_heading} body={intro_body} headshot={intro_headshot} />
  <div class="section-divider" data-divider aria-hidden="true" />
  <ServicePreview services={activeServices} />
</Layout>

<script>
  // Animate section dividers on scroll
  const dividers = document.querySelectorAll('[data-divider]')
const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible')
      }
      })
  },
    { threshold: 0.5 }
  )
dividers.forEach((el) => observer.observe(el))
</script>
