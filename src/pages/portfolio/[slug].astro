---
import Layout from '@/layouts/Layout.astro'
import GalleryGrid from '@/components/portfolio/GalleryGrid.tsx'
import HeroCarousel from '@/components/home/HeroCarousel'
import SectionLabel from '@/components/shared/SectionLabel.astro'
import { getCollection } from 'astro:content'
import { generateSelectionScript } from '@/lib/hero-selection'
import {
  processImages,
  buildHeroSlides,
  buildSubcategoryHeroMap,
  loadPortraitsGalleryImages,
  type HeroSlide,
} from '@/lib/gallery-utils'
import { SITE_NAME, SITE_URL } from '@/lib/constants'

export async function getStaticPaths() {
  const galleries = await getCollection('portfolio')
  // Exclude sub-categories - they redirect to /portfolio/portraits?filter=X
  return galleries
    .filter(entry => !['family', 'couples', 'maternity'].includes(entry.slug))
    .map(entry => ({
      params: { slug: entry.slug },
      props: { entry },
    }))
}

const { entry } = Astro.props
const {
  title,
  category,
  description,
  cover,
  cover_position = 'center',
  cover_focal_x,
  cover_focal_y,
  carousel_mode = 'auto',
  carousel_count = 4,
  hero_images,
  hero_carousel_speed = 6,
  images,
  sort_mode,
} = entry.data

// Focal point calculation
const presetMap: Record<string, string> = { top: 'center top', center: 'center center', bottom: 'center bottom', left: 'left center', right: 'right center' }
const x = cover_focal_x != null ? Number(cover_focal_x) : null
const y = cover_focal_y != null ? Number(cover_focal_y) : null
const _objPos = x != null && y != null ? `${x}% ${y}%` : (presetMap[cover_position] ?? 'center center')
void _objPos // Reserved for future cover positioning

const coverSrc = typeof cover === 'string' ? cover : cover.src

// Build hero slides
const { slides: defaultHeroSlides, usePreSelection: baseUsePreSelection } = buildHeroSlides(
  images,
  hero_images,
  coverSrc,
  cover_focal_x,
  cover_focal_y,
  carousel_mode,
  carousel_count
)

// For portraits page, build subcategory hero map
let subcategoryHeroMap: Record<string, HeroSlide[]> | null = null
let usePreSelection = baseUsePreSelection

if (entry.slug === 'portraits') {
  subcategoryHeroMap = await buildSubcategoryHeroMap(defaultHeroSlides)
  usePreSelection = true
}

const isCarousel = defaultHeroSlides.length > 1 || subcategoryHeroMap !== null

// Build gallery images
const galleryImages = entry.slug === 'portraits'
  ? await loadPortraitsGalleryImages(images ?? [])
  : processImages(images ?? [], category)

const initialFilter: string | null = null
---

<Layout title={title} description={description} image={coverSrc}>
  {/* ImageGallery + BreadcrumbList schema for SEO */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ImageGallery',
    name: `${title} Photography | ${SITE_NAME}`,
    description: description || `${title} photography portfolio by ${SITE_NAME}`,
    url: `${SITE_URL}/portfolio/${entry.slug}`,
    numberOfItems: galleryImages.length,
    image: galleryImages.slice(0, 10).map((img, i) => ({
      '@type': 'ImageObject',
      url: `${SITE_URL}${img.src}`,
      name: `${title} photo ${i + 1}`,
    })),
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
      { '@type': 'ListItem', position: 2, name: 'Portfolio', item: `${SITE_URL}/portfolio` },
      { '@type': 'ListItem', position: 3, name: title, item: `${SITE_URL}/portfolio/${entry.slug}` },
    ],
  })} />

  {/* Inject pool JSON for client-side selection */}
  {usePreSelection && (
    <script type="application/json" id={`hero-${entry.slug}-pool`} set:html={JSON.stringify(defaultHeroSlides)} />
  )}

  {/* Inject selection script - runs before React hydration */}
  {usePreSelection && (
    <script is:inline set:html={generateSelectionScript(`hero-${entry.slug}-pool`, carousel_count, entry.slug)} />
  )}

  <!-- Hero with optional carousel -->
  {isCarousel ? (
    <HeroCarousel
      client:load
      slides={defaultHeroSlides}
      heading={title}
      speedSeconds={hero_carousel_speed}
      fallbackFocalX={x ?? 50}
      fallbackFocalY={y ?? 30}
      variant="portfolio"
      subcategoryHeroMap={subcategoryHeroMap}
      usePreSelection={usePreSelection}
      pageId={entry.slug}
      displayCount={carousel_count}
    />
  ) : (
    <section class="relative min-h-[60vh] md:min-h-[70vh] overflow-hidden bg-[var(--sol-cream)]">
      <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E&quot;);"></div>

      <div class="absolute inset-0 flex items-center justify-center px-8 md:px-16 lg:px-24 pt-8 pb-28">
        <div class="relative max-w-3xl w-full animate-fade-in-up">
          <div class="relative bg-white p-1 md:p-1.5 shadow-xl" style="transform: rotate(-0.5deg);">
            <img
              src={coverSrc}
              alt={title}
              class="w-full h-auto block"
              loading="eager"
            />
          </div>
        </div>
      </div>

      <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-[var(--sol-cream)] via-[var(--sol-cream)]/80 to-transparent pointer-events-none z-[15]"></div>

      <div class="absolute inset-x-0 bottom-0 z-[20] px-6 pb-12 md:pb-16 text-center">
        <div class="hero-text-eyebrow mb-2">
          <SectionLabel>{category}</SectionLabel>
        </div>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-light text-[var(--sol-charcoal)] hero-text-heading">{title}</h1>
      </div>
    </section>
  )}

  {description && (
    <p class="max-w-xl mx-auto px-6 pt-12 text-center font-serif text-[var(--sol-charcoal)]/80 leading-relaxed hero-text-body">
      {description}
    </p>
  )}

  <div class="text-center pt-8 hero-text-cta">
    <a
      href={`#inquiry?context=${entry.slug}`}
      class="cta-underline cta-arrow"
    >
      Inquire about {title.toLowerCase()}
      <svg viewBox="0 0 24 24" class="w-4 h-4 stroke-current stroke-[1.5]" fill="none">
        <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
  </div>

  <script is:inline>
    (function() {
      const container = document.getElementById('gallery-parallax')
      if (!container) return
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return
      window.addEventListener('scroll', function parallaxScroll() {
        const rect = container.getBoundingClientRect()
        if (rect.bottom > 0) {
          container.style.setProperty('--scroll-y', window.scrollY + 'px')
        }
      }, { passive: true })
    })()
  </script>

  <GalleryGrid
    client:load
    images={galleryImages}
    title={title}
    sortMode={sort_mode ?? 'manual'}
    category={category}
    initialFilter={initialFilter}
  />
</Layout>
