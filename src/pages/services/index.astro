---
import Layout from '@/layouts/Layout.astro'
import Hero from '@/components/home/Hero.astro'
import BookingButton from '@/components/BookingButton'
import ServiceBlock from '@/components/services/ServiceBlock.astro'
import ProcessTimeline from '@/components/services/ProcessTimeline.astro'
import { getEntry, getCollection } from 'astro:content'
import { getAllMoodImages } from '@/lib/carousel-images'

const page = await getEntry('pages', 'services')
const portfolios = await getCollection('portfolio')
const {
  page_heading,
  page_intro,
  services,
  location,
  process,
  closing,
  hero_carousel_speed = 8,
} = page.data

// Get FULL mood image pool for client-side selection
const allMoodImages = getAllMoodImages()

// Build a map of portfolio slug → images for auto-sourcing
type CarouselImg = { src: string, focal_x?: number, focal_y?: number }
const portfolioImagesMap = new Map<string, CarouselImg[]>()
for (const p of portfolios) {
  const visibleImages: CarouselImg[] = (p.data.images ?? [])
    .filter((img) => !img.hidden && img.orientation === 'portrait')
    .map((img) => ({ src: img.src }))
  portfolioImagesMap.set(p.slug, visibleImages)
}

// Resolve carousel images for each service
const activeServices = services
  .filter((s) => s.portfolio_slug)
  .map((s) => {
    const carouselMode = s.carousel_mode ?? 'auto'
    if (carouselMode === 'auto' && s.portfolio_slug) {
      const portfolioImages = portfolioImagesMap.get(s.portfolio_slug) ?? []
      const shuffled = [...portfolioImages].sort(() => Math.random() - 0.5)
      return { ...s, carousel_images: shuffled }
    }
    return s
  })
---

<Layout title="Services" description={page_intro}>
  <Hero
    slides={allMoodImages}
    heading={page_heading}
    position="center"
    carouselSpeed={hero_carousel_speed}
    usePreSelection={true}
    poolId="hero-services-pool"
    pageId="services"
    displayCount={4}
  />

  {/* Location block */}
  {location && (
    <section class="bg-[var(--sol-sage)]/20 py-12">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="font-display text-2xl text-[var(--sol-charcoal)] mb-4">{location.heading}</h2>
        <p class="font-serif text-[var(--sol-charcoal)]/80 leading-relaxed text-lg" set:html={location.description} />
      </div>
    </section>
  )}

  <section class="max-w-7xl mx-auto px-6 py-20">
    {page_intro && (
      <p class="font-serif text-lg text-[var(--sol-charcoal)]/70 text-center max-w-xl mx-auto leading-relaxed mb-16 animate-on-scroll">
        {page_intro}
      </p>
    )}

    <div class="space-y-32">
      {activeServices.map((service, idx) => (
        <div id={service.portfolio_slug} class="scroll-mt-24">
          <ServiceBlock
            name={service.name}
            tagline={service.tagline}
            description={service.description}
            ideal_for={service.ideal_for}
            packages={service.packages}
            starting_note={service.starting_note}
            what_to_expect={service.what_to_expect}
            carousel_images={service.carousel_images}
            portfolio_slug={service.portfolio_slug}
            subcategories={service.subcategories}
            serviceNumber={String(idx + 1).padStart(2, '0')}
            isEven={idx % 2 === 1}
          />
        </div>
      ))}
    </div>
  </section>

  {process && (
    <ProcessTimeline heading={process.heading} steps={process.steps} />
  )}

  {/* Closing CTA */}
  {closing && (
    <section class="py-20 text-center">
      <div class="max-w-2xl mx-auto px-6">
        <h2 class="font-display text-3xl lg:text-4xl text-[var(--sol-charcoal)] mb-4">
          {closing.heading}
        </h2>
        {closing.subheading && (
          <p class="font-serif text-lg text-[var(--sol-charcoal)]/70 mb-8">
            {closing.subheading}
          </p>
        )}
        <BookingButton
          client:load
          buttonText={closing.cta_text}
          variant="premium"
        />
      </div>
    </section>
  )}
</Layout>
