---
import Layout from '@/layouts/Layout.astro'
import Hero from '@/components/home/Hero.astro'
import BookingButton from '@/components/BookingButton'
import ServiceCarousel from '@/components/shared/ServiceCarousel'
import ServiceBento from '@/components/services/ServiceBento'
import { getEntry, getCollection } from 'astro:content'
import { getMoodImages } from '@/lib/carousel-images'

const page = await getEntry('pages', 'services')
const portfolios = await getCollection('portfolio')
const {
  page_heading,
  page_intro,
  services,
  location,
  process,
  closing,
  hero_carousel_speed = 8,
} = page.data

// Auto-source hero images from mood photos (randomized at build time)
const heroSlides = getMoodImages(3, true)

// Build a map of portfolio slug → images for auto-sourcing
type CarouselImg = { src: string, focal_x?: number, focal_y?: number }
const portfolioImagesMap = new Map<string, CarouselImg[]>()
for (const p of portfolios) {
  const visibleImages: CarouselImg[] = (p.data.images ?? [])
    .filter((img) => !img.hidden && img.orientation === 'portrait')
    .map((img) => ({ src: img.src }))
  portfolioImagesMap.set(p.slug, visibleImages)
}

// Resolve carousel images for each service - pass ALL images for infinite scroll
const activeServices = services
  .filter((s) => s.portfolio_slug)
  .map((s) => {
    const carouselMode = s.carousel_mode ?? 'auto'

    if (carouselMode === 'auto' && s.portfolio_slug) {
      const portfolioImages = portfolioImagesMap.get(s.portfolio_slug) ?? []
      // Shuffle for variety but pass ALL images - components handle progressive loading
      const shuffled = [...portfolioImages].sort(() => Math.random() - 0.5)
      return {
        ...s,
        carousel_images: shuffled,
      }
    }
    return s
  })

// Format price for display
function formatPrice(price: number | null | undefined, priceNote?: string): string {
  if (priceNote) return priceNote
  if (price == null) return 'Contact for pricing'
  return `$${price}`
}
---

<Layout title="Services" description={page_intro}>
  {/* Hero section */}
  <Hero
    slides={heroSlides}
    heading={page_heading}
    position="center"
    carouselSpeed={hero_carousel_speed}
  />

  {/* Location block */}
  {location && (
    <section class="bg-[var(--sol-sage)]/20 py-12">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="font-display text-2xl text-[var(--sol-charcoal)] mb-4">{location.heading}</h2>
        <p class="font-serif text-[var(--sol-charcoal)]/80 leading-relaxed text-lg">
          {location.description}
        </p>
      </div>
    </section>
  )}

  <section class="max-w-7xl mx-auto px-6 py-20">
    {/* Intro text */}
    {page_intro && (
      <p class="font-serif text-lg text-[var(--sol-charcoal)]/70 text-center max-w-xl mx-auto leading-relaxed mb-16 animate-on-scroll">
        {page_intro}
      </p>
    )}

    {/* Services */}
    <div class="space-y-32">
      {activeServices.map((service, idx) => {
        const {
          name,
          tagline,
          description,
          ideal_for,
          packages,
          what_to_expect,
          carousel_images,
          portfolio_slug,
          subcategories,
        } = service
        const serviceNumber = String(idx + 1).padStart(2, '0')
        const isEven = idx % 2 === 1

        return (
          <article class="animate-on-scroll" id={portfolio_slug}>
            {/* Service number label */}
            <div class="flex items-center gap-4 mb-8">
              <span class="text-[var(--sol-sage)] text-sm font-sans tracking-widest">{serviceNumber}</span>
              <div class="flex-1 h-px bg-[var(--sol-sage)]/30" />
            </div>

            <div class={`grid lg:grid-cols-2 gap-8 lg:gap-12 items-start ${isEven ? 'lg:flex-row-reverse' : ''}`}>
              {/* Images: Carousel on mobile/tablet, Bento on desktop */}
              <div class={`${isEven ? 'lg:order-2' : ''}`}>
                {carousel_images && carousel_images.length > 0 ? (
                  <>
                    {/* Mobile/Tablet: Carousel */}
                    <div class="lg:hidden">
                      <ServiceCarousel
                        client:visible
                        images={carousel_images}
                        name={name}
                        portfolioSlug={portfolio_slug}
                      />
                    </div>
                    {/* Desktop: Bento grid */}
                    <div class="hidden lg:block">
                      <ServiceBento
                        client:visible
                        images={carousel_images}
                        portfolioSlug={portfolio_slug}
                        isEven={isEven}
                      />
                    </div>
                  </>
                ) : (
                  <div class="aspect-[4/3] bg-[var(--sol-sage)]/20 rounded-sm" />
                )}
              </div>

              {/* Content - sticky on desktop */}
              <div class={`lg:sticky lg:top-24 lg:max-w-md ${isEven ? 'lg:order-1' : ''}`}>
                {/* Title and tagline */}
                <a
                  href={`/portfolio/${portfolio_slug}`}
                  class="block hover:text-[var(--sol-caramel)] transition-colors group"
                >
                  <h2 class="font-display text-4xl lg:text-5xl text-[var(--sol-charcoal)] mb-2 group-hover:text-[var(--sol-caramel)]">
                    {name}
                  </h2>
                  {tagline && (
                    <p class="font-serif text-[var(--sol-caramel)] text-lg italic mb-4">{tagline}</p>
                  )}
                </a>

                <p class="font-serif text-[var(--sol-charcoal)]/80 leading-relaxed text-lg mb-6">
                  {description}
                </p>

                {/* Ideal for */}
                {ideal_for && ideal_for.length > 0 && (
                  <div class="mb-8">
                    <h4 class="font-sans text-xs tracking-widest uppercase text-[var(--sol-charcoal)]/60 mb-3">
                      Ideal for
                    </h4>
                    <div class="flex flex-wrap gap-2">
                      {ideal_for.map((item) => (
                        <span class="inline-block px-3 py-1 bg-[var(--sol-sage)]/30 text-[var(--sol-charcoal)]/80 text-sm font-serif rounded-full">
                          {item}
                        </span>
                      ))}
                    </div>
                  </div>
                )}

                {/* Subcategory filters (for portrait) */}
                {subcategories && subcategories.length > 0 && (
                  <div class="flex flex-wrap gap-3 mb-6">
                    {subcategories.map((sub, subIdx) => (
                      <a
                        href={`/portfolio/${portfolio_slug}?filter=${sub.filter}`}
                        class="group relative inline-block"
                      >
                        <span class="font-display text-lg text-[var(--sol-charcoal)] relative z-10 px-1 group-hover:text-[var(--sol-forest)] transition-colors">
                          {sub.label}
                        </span>
                        <span
                          class="absolute inset-0 -skew-x-3 bg-[var(--sol-sage)]/40 group-hover:bg-[var(--sol-sage)]/60 transition-colors"
                          style={`transform: skewX(${subIdx % 2 === 0 ? '-3' : '2'}deg) rotate(${subIdx % 2 === 0 ? '-1' : '1'}deg);`}
                        />
                      </a>
                    ))}
                  </div>
                )}

                {/* Packages */}
                {packages && packages.length > 0 && (
                  <div class="mb-8 space-y-4">
                    <h4 class="font-sans text-xs tracking-widest uppercase text-[var(--sol-charcoal)]/60 mb-3">
                      Session packages
                    </h4>
                    <div class="space-y-3">
                      {packages.map((pkg) => (
                        <div class="group border-l-2 border-[var(--sol-sage)]/40 hover:border-[var(--sol-caramel)] pl-4 py-2 transition-colors">
                          <div class="flex justify-between items-baseline mb-1">
                            <span class="font-sans font-medium text-[var(--sol-charcoal)]">
                              {pkg.name}
                            </span>
                            <span class="font-display text-lg text-[var(--sol-caramel)]">
                              {formatPrice(pkg.starting_price, pkg.price_note)}
                            </span>
                          </div>
                          <div class="flex justify-between items-baseline">
                            <span class="text-sm text-[var(--sol-charcoal)]/60">{pkg.duration}</span>
                          </div>
                          <ul class="mt-2 text-sm text-[var(--sol-charcoal)]/70 space-y-0.5">
                            {pkg.includes.slice(0, 3).map((item) => (
                              <li class="flex items-center gap-2">
                                <span class="w-1 h-1 bg-[var(--sol-sage)] rounded-full flex-shrink-0" />
                                {item}
                              </li>
                            ))}
                            {pkg.includes.length > 3 && (
                              <li class="text-[var(--sol-charcoal)]/50 italic">
                                +{pkg.includes.length - 3} more
                              </li>
                            )}
                          </ul>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {/* What to expect */}
                {what_to_expect && (
                  <div class="mb-8 p-4 bg-[var(--sol-cream)] border border-[var(--sol-sage)]/30 rounded-sm">
                    <h4 class="font-sans text-xs tracking-widest uppercase text-[var(--sol-charcoal)]/60 mb-2">
                      What to expect
                    </h4>
                    <p class="font-serif text-sm text-[var(--sol-charcoal)]/80 leading-relaxed">
                      {what_to_expect}
                    </p>
                  </div>
                )}

                {/* CTAs */}
                <div class="flex gap-4 flex-wrap items-center">
                  <a
                    href={`/portfolio/${portfolio_slug}`}
                    class="group relative inline-flex items-center gap-2 px-5 py-2.5 rounded-md font-sans text-xs tracking-widest uppercase border-2 border-[var(--sol-charcoal)]/80 text-[var(--sol-charcoal)] overflow-hidden transition-all hover:-translate-y-0.5"
                  >
                    <span class="absolute inset-0 bg-[var(--sol-charcoal)] translate-y-full group-hover:translate-y-0 transition-transform duration-300" />
                    <span class="relative z-10 group-hover:text-[var(--sol-cream)] transition-colors duration-300">View Portfolio</span>
                  </a>
                  <BookingButton
                    client:load
                    portfolioSlug={portfolio_slug}
                    buttonText="Book Now"
                  />
                </div>
              </div>
            </div>
          </article>
        )
      })}
    </div>
  </section>

  {/* Process section */}
  {process && (
    <section class="bg-[var(--sol-charcoal)] text-[var(--sol-cream)] py-20">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="font-display text-3xl lg:text-4xl text-center mb-16">{process.heading}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-4">
          {process.steps.map((step, idx) => (
            <div class="relative text-center lg:text-left">
              {/* Connector line (desktop only) */}
              {idx < process.steps.length - 1 && (
                <div class="hidden lg:block absolute top-8 left-1/2 w-full h-px bg-[var(--sol-sage)]/30" />
              )}
              <div class="relative z-10">
                <span class="inline-block font-sans text-[var(--sol-sage)] text-sm tracking-widest mb-2">
                  {step.number}
                </span>
                <h3 class="font-display text-2xl mb-2">{step.title}</h3>
                <p class="font-serif text-[var(--sol-cream)]/70 text-sm leading-relaxed">
                  {step.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Closing CTA */}
  {closing && (
    <section class="py-20 text-center">
      <div class="max-w-2xl mx-auto px-6">
        <h2 class="font-display text-3xl lg:text-4xl text-[var(--sol-charcoal)] mb-4">
          {closing.heading}
        </h2>
        {closing.subheading && (
          <p class="font-serif text-lg text-[var(--sol-charcoal)]/70 mb-8">
            {closing.subheading}
          </p>
        )}
        <BookingButton
          client:load
          buttonText={closing.cta_text}
          variant="premium"
        />
      </div>
    </section>
  )}
</Layout>
