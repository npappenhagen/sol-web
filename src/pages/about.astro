---
import Layout from '@/layouts/Layout.astro';
import SectionLabel from '@/components/shared/SectionLabel.astro';
import { getEntry } from 'astro:content';

const about = await getEntry('pages', 'about');
const { hero_image, heading, subheading, bio, headshot } = about.data;
---

<Layout title="About" description={subheading}>
  <!-- Hero banner -->
  <section class="relative h-[70vh] min-h-[420px] overflow-hidden">
    <img
      src={hero_image}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-[var(--sol-charcoal)]/35" />
    <div class="relative h-full flex items-end justify-center pb-16 px-6 text-center">
      <div>
        <SectionLabel>About</SectionLabel>
        <h1 class="font-display text-5xl md:text-7xl text-[var(--sol-cream)] mt-3">{heading}</h1>
      </div>
    </div>
  </section>

  <!-- Bio -->
  <section class="max-w-4xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-16 items-center">
    <img
      src={headshot}
      alt={heading}
      class="w-full aspect-[3/4] object-cover"
      loading="lazy"
    />
    <div>
      <p class="font-sans text-xs tracking-widest uppercase text-[var(--sol-caramel)] mb-4">{subheading}</p>
      <p class="font-serif text-lg text-[var(--sol-charcoal)]/85 leading-relaxed">{bio}</p>
      <a
        href="/contact"
        class="inline-block mt-10 font-sans text-xs tracking-widest uppercase px-8 py-3 border border-[var(--sol-caramel)] text-[var(--sol-caramel)] hover:bg-[var(--sol-caramel)] hover:text-[var(--sol-cream)] transition-colors"
      >
        Inquire
      </a>
    </div>
  </section>
</Layout>
