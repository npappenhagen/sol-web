---
import Layout from '@/layouts/Layout.astro'
import Hero from '@/components/home/Hero.astro'
import { getEntry } from 'astro:content'
import { getAllMoodImages } from '@/lib/carousel-images'
import { SITE_NAME, SITE_URL, SOCIAL_PROFILES, SERVICE_AREAS } from '@/lib/constants'

const about = await getEntry('pages', 'about')
const {
  hero_position = 'center',
  hero_focal_x,
  hero_focal_y,
  hero_carousel_speed = 7,
  heading,
  subheading,
  bio,
  headshot,
  headshots,
} = about.data

// Use headshots array if available, otherwise fall back to single headshot
const collageImages = headshots && headshots.length >= 3 ? headshots.slice(0, 3) : null

// Get FULL mood image pool for client-side selection
// All 53 mood images are passed to Hero; the client selects which 4 to display
const allMoodImages = getAllMoodImages()
---

<Layout title="About" description={subheading} image={headshot}>
  {/* Person + BreadcrumbList schema for SEO */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Laurel',
    jobTitle: 'Photographer',
    description: subheading,
    image: `${SITE_URL}${headshot}`,
    url: `${SITE_URL}/about`,
    sameAs: [...SOCIAL_PROFILES],
    worksFor: {
      '@type': 'Organization',
      name: SITE_NAME,
      url: SITE_URL,
    },
    workLocation: {
      '@type': 'Place',
      name: 'Guanacaste, Costa Rica',
    },
    knowsAbout: ['Portrait Photography', 'Family Photography', 'Branding Photography', 'Retreat Photography'],
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
      { '@type': 'ListItem', position: 2, name: 'About', item: `${SITE_URL}/about` },
    ],
  })} />

  <!-- Hero banner with carousel support -->
  <Hero
    slides={allMoodImages}
    heading={heading}
    position={hero_position}
    focalX={hero_focal_x}
    focalY={hero_focal_y}
    carouselSpeed={hero_carousel_speed}
    usePreSelection={true}
    poolId="hero-about-pool"
    pageId="about"
    displayCount={4}
  />

  <!-- Bio -->
  <section class="max-w-5xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
    {collageImages ? (
      <div class="relative animate-on-scroll">
        <div class="grid grid-cols-12 gap-3">
          <!-- Primary image - larger, anchored -->
          <div class="col-span-8 col-start-1">
            <img
              src={collageImages[1]}
              alt={heading}
              class="w-full aspect-[3/4] object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          <!-- Secondary image - smaller, offset down -->
          <div class="col-span-5 col-start-8 -mt-[20%] relative z-10">
            <img
              src={collageImages[0]}
              alt=""
              class="w-full aspect-[3/4] object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    ) : (
      <img
        src={headshot}
        alt={heading}
        class="w-full aspect-[3/4] object-cover animate-on-scroll"
        loading="lazy"
        decoding="async"
      />
    )}
    <div class="animate-on-scroll" style="transition-delay: 0.1s;">
      <p class="font-sans text-xs tracking-widest uppercase text-[var(--sol-caramel)] mb-4">{subheading}</p>
      <p class="font-serif text-lg text-[var(--sol-charcoal)]/85 leading-relaxed">{bio}</p>
      <a
        href="#inquiry"
        class="cta-underline cta-arrow inline-flex items-center gap-2 mt-10"
      >
        Inquire
        <svg viewBox="0 0 24 24" class="w-4 h-4 stroke-current stroke-[1.5]" fill="none">
          <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </section>

</Layout>
