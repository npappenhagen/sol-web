---
import { NAV_LINKS } from '@/lib/navigation'
import NavDropdown from './NavDropdown'

const currentPath = Astro.url.pathname
const currentUrl = Astro.url.pathname + Astro.url.search

const isActive = (href: string) => currentPath === href || (href !== '/' && currentPath.startsWith(href))

const linkClass = (href: string) => [
  'nav-link nav-link-expand text-sm tracking-widest font-sans transition-colors',
  isActive(href)
    ? 'text-[var(--sol-caramel)] nav-link-active-pill'
    : 'text-[var(--sol-charcoal)] hover:text-[var(--sol-caramel)]',
].join(' ')

const mobileLinkClass = (href: string) => [
  'block text-sm tracking-widest font-sans py-3 transition-colors',
  isActive(href)
    ? 'text-[var(--sol-caramel)]'
    : 'text-[var(--sol-charcoal)] hover:text-[var(--sol-caramel)]',
].join(' ')

// Dropdown items for Portfolio and Services
// `indent` marks sub-categories that belong under a parent
const portfolioItems = [
  { href: '/portfolio/portraits', label: 'Portraits' },
  { href: '/portfolio/portraits?filter=family', label: 'Family', indent: true },
  { href: '/portfolio/portraits?filter=maternity', label: 'Maternity', indent: true },
  { href: '/portfolio/portraits?filter=couples', label: 'Couples', indent: true },
  { href: '/portfolio/branding', label: 'Branding' },
  { href: '/portfolio/events', label: 'Retreats' },
]

const serviceItems = [
  { href: '/services', label: 'All Services' },
  { href: '/services#portraits', label: 'Portraits' },
  { href: '/services#branding', label: 'Branding' },
  { href: '/services#events', label: 'Retreats' },
]

// Split links for layout
const leftLinks = NAV_LINKS.slice(0, 3) // HOME, ABOUT, PORTFOLIO
const rightLinks = NAV_LINKS.slice(3); // SERVICES, INQUIRE
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[var(--sol-cream)] border-b border-[var(--sol-sage)]/40" style="view-transition-name: nav-bar;">
  <!-- Desktop nav -->
  <nav aria-label="Main navigation" class="hidden md:grid max-w-7xl mx-auto px-6 h-24 grid-cols-3 items-center">
    <ul class="flex gap-8">
      {leftLinks.map(({ href, label, reload }) => (
        <li>
          {label === 'PORTFOLIO' ? (
            <NavDropdown
              client:only="react"
              label={label}
              href={href}
              items={portfolioItems}
              isActive={isActive(href)}
              currentUrl={currentUrl}
            />
          ) : (
            <a href={href} class={linkClass(href)} {...(reload && { 'data-astro-reload': true })} {...(isActive(href) && { 'aria-current': 'page' })}>{label}</a>
          )}
        </li>
      ))}
    </ul>
    <a href="/" class="flex flex-col items-center nav-logo-hover group">
      <span class="font-display text-2xl tracking-[0.4em] text-[var(--sol-charcoal)] group-hover:text-[var(--sol-caramel)] transition-colors">SOL</span>
      <span class="font-sans text-[10px] tracking-[0.35em] text-[var(--sol-charcoal)]/70 -mt-0.5">PHOTOGRAPHY</span>
    </a>
    <ul class="flex gap-8 justify-end">
      {rightLinks.map(({ href, label, reload }) => (
        <li>
          {label === 'SERVICES' ? (
            <NavDropdown
              client:only="react"
              label={label}
              href={href}
              items={serviceItems}
              isActive={isActive(href)}
              currentUrl={currentUrl}
            />
          ) : label === 'INQUIRE' ? (
            <a href={href} class={`${linkClass(href)} cta-arrow inline-flex items-center gap-1.5`} {...(reload && { 'data-astro-reload': true })} {...(isActive(href) && { 'aria-current': 'page' })}>
              {label}
              <svg viewBox="0 0 24 24" class="w-3 h-3 stroke-current stroke-[1.5]" fill="none" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          ) : (
            <a href={href} class={linkClass(href)} {...(reload && { 'data-astro-reload': true })} {...(isActive(href) && { 'aria-current': 'page' })}>{label}</a>
          )}
        </li>
      ))}
    </ul>
  </nav>

  <!-- Mobile nav -->
  <div class="md:hidden flex items-center justify-between px-6 h-14">
    <a href="/" class="flex items-center gap-1.5 nav-logo-hover">
      <span class="font-display text-lg tracking-[0.3em] text-[var(--sol-charcoal)]">SOL</span>
      <span class="font-sans text-[9px] tracking-[0.25em] text-[var(--sol-charcoal)]/70">PHOTOGRAPHY</span>
    </a>
    <button
      type="button"
      id="nav-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      class="w-8 h-8 flex flex-col justify-center items-center gap-1.5"
    >
      <span class="block w-5 h-px bg-[var(--sol-charcoal)] transition-transform origin-center" id="bar1" />
      <span class="block w-5 h-px bg-[var(--sol-charcoal)] transition-opacity" id="bar2" />
      <span class="block w-5 h-px bg-[var(--sol-charcoal)] transition-transform origin-center" id="bar3" />
    </button>
  </div>

  <!-- Mobile backdrop (covers inquiry widget and page content) -->
  <div
    id="mobile-backdrop"
    class="md:hidden fixed inset-0 top-14 bg-[var(--sol-cream)]/98 backdrop-blur-sm z-40 hidden transition-opacity duration-200"
    aria-hidden="true"
  ></div>

  <!-- Mobile drawer -->
  <nav
    id="mobile-menu"
    aria-label="Mobile navigation"
    class="md:hidden hidden border-t border-[var(--sol-sage)]/40 bg-[var(--sol-cream)] px-6 pb-6 relative z-50"
  >
    <ul class="flex flex-col">
      {NAV_LINKS.map(({ href, label, reload }) => (
        <>
          <li class="border-b border-[var(--sol-sage)]/20 mobile-menu-item">
            {label === 'INQUIRE' ? (
              <a href={href} class={`${mobileLinkClass(href)} cta-arrow inline-flex items-center gap-1.5`} {...(reload && { 'data-astro-reload': true })} {...(isActive(href) && { 'aria-current': 'page' })}>
                {label}
                <svg viewBox="0 0 24 24" class="w-3 h-3 stroke-current stroke-[1.5]" fill="none" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            ) : (
              <a href={href} class={mobileLinkClass(href)} {...(reload && { 'data-astro-reload': true })} {...(isActive(href) && { 'aria-current': 'page' })}>{label}</a>
            )}
          </li>
          {/* Portfolio sub-links */}
          {label === 'PORTFOLIO' && (
            <li class="border-b border-[var(--sol-sage)]/20">
              <div class="pl-4 flex flex-col">
                {portfolioItems.map((item) => (
                  <a
                    href={item.href}
                    class:list={[
                      "text-xs tracking-widest font-sans py-2 transition-colors",
                      item.indent ? "pl-3 opacity-60" : "",
                      currentUrl === item.href
                        ? "text-[var(--sol-caramel)] opacity-100"
                        : "text-[var(--sol-charcoal)]/70 hover:text-[var(--sol-caramel)] hover:opacity-100"
                    ]}
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </li>
          )}
          {/* Services sub-links */}
          {label === 'SERVICES' && (
            <li class="border-b border-[var(--sol-sage)]/20">
              <div class="pl-4 flex flex-col">
                {serviceItems.map((item) => (
                  <a
                    href={item.href}
                    class:list={[
                      "text-xs tracking-widest font-sans py-2 transition-colors",
                      currentUrl === item.href
                        ? "text-[var(--sol-caramel)]"
                        : "text-[var(--sol-charcoal)]/70 hover:text-[var(--sol-caramel)]"
                    ]}
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </li>
          )}
        </>
      ))}
    </ul>
  </nav>
</header>

<!-- Push content below fixed nav -->
<div class="h-14 md:h-24" aria-hidden="true" />

<script>
  import '@/scripts/nav-toggle'
</script>
