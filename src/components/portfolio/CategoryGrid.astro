---
import { getCollection } from 'astro:content'
import { getObjectPosition } from '@/lib/image-position'
import { getSrcSet, getDefaultSrc, hasVariants } from '@/lib/image-url'

const galleries = await getCollection('portfolio')

// Get category data - single cover image per category
const categories = [
  { slug: 'portraits', label: 'Portraits' },
  { slug: 'branding', label: 'Branding' },
  { slug: 'events', label: 'Retreats' },
].map(cat => {
  const entry = galleries.find(g => g.slug === cat.slug)
  const position = getObjectPosition(
    entry?.data.cover_focal_x,
    entry?.data.cover_focal_y,
    entry?.data.cover_position ?? 'center'
  )

  return {
    ...cat,
    image: entry?.data.cover ?? '',
    position,
  }
});
---

<section class="max-w-6xl mx-auto px-4 lg:px-8">
  <div class="flex flex-col gap-4 lg:gap-6">
    {categories.map(({ slug, label, image, position }) => (
      <a
        href={`/portfolio/${slug}`}
        class="category-panel group relative block h-[50vh] min-h-[350px] lg:min-h-[400px] overflow-hidden rounded-sm"
      >
        {/* Responsive image with WebP support */}
        {hasVariants(image) ? (
          <picture class="absolute inset-0">
            <source
              type="image/webp"
              srcset={getSrcSet(image)}
              sizes="(max-width: 768px) 100vw, (max-width: 1024px) 80vw, 1200px"
            />
            <img
              src={getDefaultSrc(image, 'hero')}
              alt={`${label} photography portfolio`}
              class="w-full h-full object-cover"
              style={`object-position: ${position};`}
              loading="lazy"
              decoding="async"
            />
          </picture>
        ) : (
          <img
            src={image}
            alt={`${label} photography portfolio`}
            class="absolute inset-0 w-full h-full object-cover"
            style={`object-position: ${position};`}
            loading="lazy"
            decoding="async"
          />
        )}

        {/* Overlay - darkens on hover */}
        <div class="absolute inset-0 bg-black/25 group-hover:bg-black/40 transition-colors duration-300" />

        {/* Category label */}
        <div class="absolute inset-0 flex items-center justify-center">
          <h2 class="font-display text-6xl md:text-8xl lg:text-9xl font-light italic text-[var(--sol-cream)] tracking-wide hero-headline">
            {label}
          </h2>
        </div>
      </a>
    ))}
  </div>
</section>
