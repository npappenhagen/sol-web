---
import SectionLabel from '@/components/shared/SectionLabel.astro';

interface Props {
  label: string;
  heading: string;
  body: string;
  ctaHref?: string;
  ctaText?: string;
}
const { label, heading, body, ctaHref = '/contact', ctaText = 'Work with me' } = Astro.props;
---

<section class="max-w-2xl mx-auto px-6 py-24 text-center">
  <SectionLabel>{label}</SectionLabel>
  <h2 class="font-display text-4xl md:text-5xl text-[var(--sol-charcoal)] mt-4 mb-6 leading-tight">
    {heading}
  </h2>
  <p class="font-serif text-[var(--sol-charcoal)]/80 leading-relaxed text-lg mb-10">
    {body}
  </p>
  <a
    href={ctaHref}
    class="inline-block font-sans text-xs tracking-widest uppercase px-8 py-3 border border-[var(--sol-caramel)] text-[var(--sol-caramel)] hover:bg-[var(--sol-caramel)] hover:text-[var(--sol-cream)] transition-colors"
  >
    {ctaText}
  </a>
</section>
