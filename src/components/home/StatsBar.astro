---
interface Stat {
  number: string
  label: string
}
interface Props {
  stats: Stat[]
}
const { stats } = Astro.props;
---

<section class="bg-[var(--sol-charcoal)] py-14 animate-on-scroll" data-animate>
  <ul class="max-w-4xl mx-auto px-6 flex flex-wrap justify-center items-center gap-y-8">
    {stats.map(({ number, label }, idx) => (
      <>
        {idx > 0 && <li class="hidden md:block stat-divider mx-8" aria-hidden="true" />}
        <li class="text-center px-4">
          <p class="font-display text-4xl leading-[1.1] stat-number-enhanced">{number}</p>
          <p class="font-sans text-xs tracking-widest uppercase text-[var(--sol-sage)] mt-1 stat-label-enhanced">{label}</p>
        </li>
      </>
    ))}
  </ul>
</section>
