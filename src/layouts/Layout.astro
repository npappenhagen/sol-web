---
import '../styles/global.css';
import Nav from '@/components/layout/Nav.astro';
import Footer from '@/components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Sol Photography — family, wedding, architecture, and branding photography.',
  image = '/media/site/og-image.jpg',
} = Astro.props;

const fullTitle = title === 'Home' ? 'Sol Photography' : `${title} | Sol Photography`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(image, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl.href} />
    <meta name="theme-color" content="#F5F0E8" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:site_name" content="Sol Photography" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.href} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ProfessionalService',
      name: 'Sol Photography',
      url: 'https://solphotography.net',
      description: 'Family, wedding, architecture, and branding photography.',
      image: ogImageUrl.href,
      priceRange: '$$',
      '@id': 'https://solphotography.net/#business',
      serviceType: ['Family Photography', 'Wedding Photography', 'Architecture Photography', 'Branding Photography'],
    })} />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
