---
import { ViewTransitions } from 'astro:transitions'
import '../styles/global.css'
import Nav from '@/components/layout/Nav.astro'
import Footer from '@/components/layout/Footer.astro'
import InquiryWidget from '@/components/InquiryWidget'
import CalProvider from '@/components/CalProvider'
import { SITE_NAME, SITE_DESCRIPTION, THEME_COLOR, SERVICE_TYPES, DEFAULTS } from '@/lib/constants'

interface Props {
  title: string
  description?: string
  image?: string
}

const {
  title,
  description = SITE_DESCRIPTION,
  image = DEFAULTS.OG_IMAGE,
} = Astro.props

const fullTitle = title === 'Home' ? SITE_NAME : `${title} | ${SITE_NAME}`
const canonicalUrl = new URL(Astro.url.pathname, Astro.site)
const ogImageUrl = new URL(image, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalUrl.href} />
    <meta name="theme-color" content={THEME_COLOR} />

    <!-- Preconnect to third-party origins for faster resource loading -->
    <link rel="preconnect" href="https://app.cal.com" crossorigin />
    <link rel="dns-prefetch" href="https://app.cal.com" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:site_name" content={SITE_NAME} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.href} />

    <!-- View Transitions with fade animation -->
    <ViewTransitions />

    <style is:global>
      /* View Transition: Cinematic fade with gentle movement */
      @keyframes fade-in {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      @keyframes fade-out {
        from { opacity: 1; }
        to { opacity: 0; }
      }
      @keyframes content-enter {
        from {
          opacity: 0;
          transform: translateY(16px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes content-exit {
        from {
          opacity: 1;
          transform: translateY(0);
        }
        to {
          opacity: 0;
          transform: translateY(-8px);
        }
      }

      /* Root transition: smooth cross-fade */
      ::view-transition-old(root) {
        animation: fade-out 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
      }
      ::view-transition-new(root) {
        animation: fade-in 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
      }

      /* Main content: elegant slide with overlap for continuity */
      ::view-transition-old(main-content) {
        animation: content-exit 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
      }
      ::view-transition-new(main-content) {
        animation: content-enter 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.1s forwards;
        opacity: 0;
      }

      /* Nav stays stable during transition */
      ::view-transition-old(nav-bar),
      ::view-transition-new(nav-bar) {
        animation: none;
        mix-blend-mode: normal;
      }

      /* Respect reduced motion */
      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root),
        ::view-transition-new(root),
        ::view-transition-old(main-content),
        ::view-transition-new(main-content) {
          animation: none;
        }
      }
    </style>

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ProfessionalService',
      name: SITE_NAME,
      url: Astro.site?.href ?? 'https://solphotography.net',
      description: 'Portrait, branding, and retreat photography.',
      image: ogImageUrl.href,
      priceRange: '$$',
      '@id': `${Astro.site?.href ?? 'https://solphotography.net'}#business`,
      serviceType: [...SERVICE_TYPES],
    })} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-[var(--sol-cream)] focus:px-4 focus:py-2 focus:text-sm focus:font-sans focus:tracking-widest">
      Skip to content
    </a>
    <Nav />
    <main id="main" style="view-transition-name: main-content;">
      <slot />
    </main>
    <CalProvider client:only="react" />
    <InquiryWidget client:only="react" />
    <Footer />

    <!-- Scroll-triggered animation observer -->
    <script is:inline>
      function initScrollAnimations() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible')
          observer.unobserve(entry.target)
        }
            })
    },
          { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
        )
  document.querySelectorAll('.animate-on-scroll').forEach((el) => {
          // Reset visibility for fresh animations on page transitions
          el.classList.remove('is-visible')
    observer.observe(el)
  })
      }

      // Run on initial page load
      initScrollAnimations()

// Re-run after View Transitions complete
document.addEventListener('astro:page-load', initScrollAnimations)
    </script>
  </body>
</html>
