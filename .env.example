# Resend (https://resend.com) — required for contact form
RESEND_API_KEY=re_...

# Who receives contact form submissions
CONTACT_TO=your@email.com

# Who the email appears to come from (must be a verified Resend domain in production)
# During dev/testing you can use: onboarding@resend.dev
CONTACT_FROM=hello@solphotography.net
